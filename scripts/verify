#!/usr/bin/env bash
set -euo pipefail

repo_root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$repo_root"

before_tidy="$(mktemp)"
after_tidy="$(mktemp)"
trap 'rm -f "$before_tidy" "$after_tidy"' EXIT

git diff -- go.mod go.sum >"$before_tidy"
go mod tidy
git diff -- go.mod go.sum >"$after_tidy"
if ! diff -u "$before_tidy" "$after_tidy"; then
	echo "go mod tidy changed go.mod or go.sum; run go mod tidy and commit the result" >&2
	exit 1
fi
coverage_out="$(mktemp)"
coverage_filtered="$(mktemp)"
trap 'rm -f "$before_tidy" "$after_tidy" "$coverage_out" "$coverage_filtered"' EXIT
go test -count=1 -coverprofile="$coverage_out" ./...
# Exclude the CLI entry point — main() exits the process, not unit-testable.
grep -v '^github.com/uinaf/fincrawl/cmd/fincrawl/' "$coverage_out" >"$coverage_filtered"
total="$(go tool cover -func="$coverage_filtered" | awk '/^total:/ { sub(/%$/, "", $3); print $3 }')"
floor="${FINCRAWL_COVERAGE_FLOOR:-80}"
if [[ -z "$total" ]] || ! awk -v t="$total" 'BEGIN { exit (t+0 > 0) ? 0 : 1 }'; then
	echo "coverage is ${total:-<empty>}%; refusing to ship a fully-untested tree" >&2
	exit 1
fi
printf 'coverage %.1f%% (floor %s%%)\n' "$total" "$floor"
if ! awk -v t="$total" -v f="$floor" 'BEGIN { exit (t+0 >= f+0) ? 0 : 1 }'; then
	echo "coverage ${total}% is below floor ${floor}%; raise the floor or add tests" >&2
	exit 1
fi
go vet ./...
go test -count=1 -race ./...
./scripts/smoke
go run ./cmd/fincrawl guard --json
./scripts/release-check
./scripts/lint
git diff --check

echo "verify ok"
