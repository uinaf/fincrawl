# Copy to a private template outside Git or use directly as an input template:
#   op inject -i .env.local.example -o .env.local
#
# Keep real 1Password references and injected values out of Git. The values
# below are placeholders only.

FINCRAWL_AGE_RECIPIENT="{{ op://<vault>/<item>/<age-recipient-field> }}"
FINCRAWL_INTERCOM_TOKEN="{{ op://<vault>/<item>/<intercom-token-field> }}"
# Optional. Use only when the tenant is pinned to a regional Intercom API.
# FINCRAWL_INTERCOM_BASE_URL="https://api.eu.intercom.io"
# FINCRAWL_INTERCOM_VERSION="2.15"
